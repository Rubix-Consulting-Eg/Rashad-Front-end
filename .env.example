# API base URL (used in production and by the dev proxy)
# In dev, browser requests use /api (same-origin) and Next.js rewrites to this URL to avoid CORS.
NEXT_PUBLIC_API_BASE_URL=https://rashad.runasp.net/api

# Optional: API secret key if your backend requires it (uncomment in apiClient/client headers if needed)
# NEXT_PUBLIC_API_SECRET_KEY=
